{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    ?dataset   shst:last_seen_by_reviewer ?timestamp .
  }
}
INSERT {
  GRAPH <{{state_graph}}> {
    ?dataset   shst:last_seen_by_reviewer "{{timestamp}}"^^xsd:dateTime .
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?dataset   rdf:type          shst:Dataset .
    OPTIONAL { ?dataset shst:last_seen_by_reviewer ?timestamp . }
  }
  FILTER (?dataset = <dataset:{{dataset_uuid}}>)
}
{% endblock %}
