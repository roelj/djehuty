{% extends "prefixes.sparql" %}
{% block query %}
SELECT DISTINCT (STRAFTER(STR(?associated_author), ":") AS ?associated_author_uuid)
                ?full_name ?is_active
WHERE {
  GRAPH <{{state_graph}}> {
    ?item          shst:is_public                    true ;
                   shst:authors/rdf:rest*/rdf:first  <{{author_uri}}> ,
                                                     ?associated_author .
    ?associated_author shst:full_name                ?full_name ;
                   shst:is_active                    ?is_active .
    FILTER (?associated_author != <{{author_uri}}>)
  }
}
ORDER BY (?full_name)
{% endblock %}
