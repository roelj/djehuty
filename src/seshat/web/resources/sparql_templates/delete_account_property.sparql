{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    ?account     shst:{{predicate}}   ?object .
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?account    rdf:type             shst:Account ;
                shst:{{predicate}}    ?object .
  }
  FILTER (?account = <account:{{account_uuid}}>)
}
{% endblock %}
