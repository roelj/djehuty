{% extends "prefixes.sparql" %}
{% block query %}
SELECT DISTINCT ?id ?uuid ?parent_id ?parent_uuid ?title ?source_id ?taxonomy_id
WHERE {
  GRAPH <{{state_graph}}> {
    ?category        rdf:type             shst:Category .
    ?category        shst:id               ?id .
    ?category        shst:title            ?title .

    OPTIONAL {
      ?category shst:parent_id             ?parent_id .
      ?parent_category shst:id             ?parent_id .

      BIND(STRAFTER(STR(?parent_category), "category:") AS ?parent_uuid)
    }

    OPTIONAL { ?category  shst:source_id   ?source_id . }
    OPTIONAL { ?category  shst:taxonomy_id ?taxonomy_id . }

    ?account         rdf:type             shst:Account .
    ?account         shst:categories/rdf:rest*/rdf:first ?category .

    BIND(STRAFTER(STR(?category), "category:") AS ?uuid)
  }
  FILTER (?account = <account:{{account_uuid}}>)
{%- if filters is not none %}{{ filters | safe }}{% endif %}
}
{% endblock %}
