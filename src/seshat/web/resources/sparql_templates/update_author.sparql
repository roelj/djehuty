{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    {%- if full_name is not none %}
    ?author       shst:full_name             ?full_name .
    {%- endif %}{% if first_name is not none %}
    ?author       shst:first_name            ?first_name .
    {%- endif%}{% if last_name is not none %}
    ?author       shst:last_name             ?last_name .
    {%- endif%}{% if email is not none %}
    ?author       shst:email                 ?email .
    {%- endif%}{% if orcid is not none %}
    ?author       shst:orcid_id              ?orcid .
    {%- endif%}{% if modified_date is not none %}
    ?author       shst:modified_date         ?modified_date .
    {%- endif%}
  }
}
INSERT {
  GRAPH <{{state_graph}}> {
    {%- if full_name is not none %}
    ?author       shst:full_name             {{full_name | safe }} .
    {%- endif %}{% if first_name is not none %}
    ?author       shst:first_name            {{first_name | safe}} .
    {%- endif%}{% if last_name is not none %}
    ?author       shst:last_name             {{last_name | safe}} .
    {%- endif%}{% if email is not none %}
    ?author       shst:email                 {{email | safe}} .
    {%- endif%}{% if orcid is not none %}
    ?author       shst:orcid_id              {{orcid | safe}} .
    {%- endif%}{% if modified_date is not none %}
    ?author       shst:modified_date         {{modified_date | safe}} .
    {%- endif%}
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?author       rdf:type                   shst:Author .
    ?author       shst:created_by            <account:{{created_by}}> .
    OPTIONAL { ?author   shst:first_name     ?first_name . }
    OPTIONAL { ?author   shst:last_name      ?last_name . }
    OPTIONAL { ?author   shst:full_name      ?full_name . }
    OPTIONAL { ?author   shst:email          ?email . }
    OPTIONAL { ?author   shst:modified_date  ?modified_date . }
  }
  FILTER (?author = <author:{{author_uuid}}>)
}
{% endblock %}
