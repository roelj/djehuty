{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    ?author    shst:orcid_id             ?orcid_id .
    ?account   shst:modified_date        ?modified_date .
  }
}
INSERT {
  GRAPH <{{state_graph}}> {
    ?author    shst:orcid_id             "{{orcid}}"^^xsd:string .
    ?account   shst:modified_date        ?now .
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?account              rdf:type                  shst:Account .
    OPTIONAL { ?account   shst:modified_date        ?modified_date . }
    OPTIONAL {
      ?author            rdf:type                   shst:Author ;
                         shst:account               ?account .
      OPTIONAL { ?author shst:orcid_id              ?orcid_id . }
    }
    BIND(NOW() AS ?now)
  }
  FILTER (?account = <account:{{account_uuid}}>)
}
{% endblock %}
