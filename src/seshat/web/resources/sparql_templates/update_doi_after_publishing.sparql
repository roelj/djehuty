{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    ?item      shst:doi          ?doi .
  }
}
INSERT {
  GRAPH <{{state_graph}}> {
    ?item      shst:doi          {{doi | safe}} .
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?item      rdf:type          shst:{{item_type.capitalize()}} .
    OPTIONAL { ?item shst:doi ?doi . }
  }
  FILTER (?item = <{{item_type}}:{{item_uuid}}>)
}
{% endblock %}
