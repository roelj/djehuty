{% extends "prefixes.sparql" %}
{% block query %}
SELECT DISTINCT ?id ?name ?url ?type
WHERE {
  GRAPH <{{state_graph}}> {
    ?url             rdf:type                 shst:License ;
                     shst:id                   ?id ;
                     shst:type/rdfs:label      ?type ;
                     shst:name                 ?name .
  }
  {%- if license_id is defined: %}
  FILTER (?id = {{license_id}})
  {%- endif %}
}
ORDER BY ASC(?type) ?name
{% endblock %}
