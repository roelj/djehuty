{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    ?dataset          shst:git_uuid            ?git_uuid .
  }
}
INSERT {
  GRAPH <{{state_graph}}> {
    ?dataset          shst:git_uuid            {{git_uuid | safe}} .
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?container            rdf:type             shst:DatasetContainer ;
                          shst:draft           ?dataset .
    OPTIONAL { ?dataset   shst:git_uuid        ?git_uuid . }
  }
  FILTER (?dataset = <dataset:{{dataset_uuid}}>)
}
{% endblock %}
