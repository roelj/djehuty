{% extends "prefixes.sparql" %}
{% block query %}
SELECT DISTINCT ?data_link ?bytes
WHERE {
  GRAPH <{{state_graph}}> {
    ?dataset    rdf:type            shst:Dataset .
    ?dataset    shst:data_link      ?data_link .
    ?dataset    shst:data_link_size ?bytes .
    ?dataset    shst:created_date   ?created .
  }
{%- if filters is not none %}{{ filters | safe }}{% endif %}
}
{% endblock %}
