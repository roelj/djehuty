{# Find the latest version of each dataset for which one of the conditions in
   the UNION clause holds and return some properties of these dataset versions.
   Filters restrict the values of ?data_url. #}
{% extends "prefixes.sparql" %}
{% block query %}
SELECT DISTINCT ?doi ?title
WHERE {
  GRAPH <{{state_graph}}> {
    ?dataset  a               shst:Dataset ;
              shst:container   ?container ;
              shst:version     ?version ;
              shst:title       ?title ;
              shst:doi         ?doi .
    {
      SELECT ?container (MAX(?i_version) AS ?version)
      WHERE {
        GRAPH <{{state_graph}}> {
          ?i_dataset  a               shst:Dataset ;
                      shst:container   ?container ;
                      shst:version     ?i_version .
          { ?i_dataset  shst:files/rdf:rest*/rdf:first  ?file .
            ?file       a                              shst:File ;
                        shst:is_link_only               true ;
                        shst:download_url               ?data_url . } UNION
          { ?i_dataset  shst:data_link                  ?data_url . }
        }
        {%- if filters is not none %}{{ filters | safe }}{% endif %}
      }
      GROUP BY ?container
    }
  }
}
{% endblock %}
