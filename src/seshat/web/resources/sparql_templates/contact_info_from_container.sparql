{% extends "prefixes.sparql" %}
{% block query %}
PREFIX this: <container:{{container_uuid}}>

SELECT DISTINCT ?account ?email ?first_name ?last_name
WHERE {
  GRAPH <{{state_graph}}> {
    this:               shst:account     ?account .
    ?account            shst:email       ?email   .
    OPTIONAL {?account  shst:first_name  ?first_name .}
    OPTIONAL {?account  shst:last_name   ?last_name  .}
  }
}
{% endblock %}
