{% extends "prefixes.sparql" %}
{% block query %}
SELECT DISTINCT ?dataset_uri ?dataset_id ?version ?url ?url_public_api ?posted_date ?container_uuid ?uuid
WHERE {
  GRAPH <{{state_graph}}> {
    ?container_uri rdf:type             shst:DatasetContainer .
    ?dataset_uri   rdf:type             shst:Dataset ;
                   shst:container       ?container_uri ;
                   shst:version         ?version ;
                   shst:posted_date     ?posted_date .

    OPTIONAL { ?dataset_uri shst:url             ?url . }
    OPTIONAL { ?dataset_uri shst:url_public_api  ?url_public_api . }
    OPTIONAL { ?container_uri shst:dataset_id ?dataset_id . }

    BIND(STRAFTER(STR(?container_uri), "container:") AS ?container_uuid)
    BIND(STRAFTER(STR(?dataset_uri), "dataset:")     AS ?uuid)
  }
{%- if container_uri is not none %}
  FILTER (?container_uri = <{{container_uri}}>)
{%- endif %}
}
{% endblock %}
