{% extends "prefixes.sparql" %}
{% block query %}
SELECT (COUNT(DISTINCT ?container) AS ?datasets)
WHERE {
  GRAPH <{{state_graph}}> {
    ?container  rdf:type                      shst:DatasetContainer ;
                shst:latest_published_version ?dataset .
    ?dataset    rdf:type                      shst:Dataset ;
                shst:is_public                "true"^^xsd:boolean .
  }
{%- if filters is not none %}{{ filters | safe }}{% endif %}
}
{% endblock %}
