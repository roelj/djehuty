{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    ?session ?predicate ?object .
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?session rdf:type shst:Session .
    ?session shst:name {{name | safe}} .
    ?session shst:created_date ?created_date .
    ?session ?predicate ?object .
  }
  FILTER (STR(?created_date) < STR({{timestamp | safe}}))
}
{% endblock %}
