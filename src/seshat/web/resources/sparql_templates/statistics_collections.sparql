{% extends "prefixes.sparql" %}
{% block query %}
SELECT (COUNT(DISTINCT ?container) AS ?collections)
WHERE {
  GRAPH <{{state_graph}}> {
    ?container  rdf:type                      shst:CollectionContainer ;
                shst:latest_published_version ?collection .
    ?collection rdf:type                      shst:Collection ;
                shst:is_public                "true"^^xsd:boolean .
  }
{%- if filters is not none %}{{ filters | safe }}{% endif %}
}
{% endblock %}
