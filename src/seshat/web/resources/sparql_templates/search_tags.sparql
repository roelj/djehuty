{% extends "prefixes.sparql" %}
{% block query %}
SELECT DISTINCT ?tag
WHERE {
  GRAPH <{{state_graph}}> {
    ?container  rdf:type/rdfs:subClassOf shst:Container .
    ?item_uri   shst:container            ?container .
    ?item_uri   shst:tags/rdf:rest*/rdf:first ?tag .
  }
{#- If it has a version, it must be a published item. #}
FILTER EXISTS { ?item_uri shst:version ?version . }
{%- if filters is not none %}{{ filters | safe }}{% endif %}
}
{% endblock %}
