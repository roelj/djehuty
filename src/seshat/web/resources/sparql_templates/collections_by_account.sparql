{% extends "prefixes.sparql" %}
{% block query %}
SELECT DISTINCT ?container_uuid ?title
WHERE {
  GRAPH <{{state_graph}}> {
    ?container_uri   rdf:type                      shst:CollectionContainer ;
                     shst:account                  <account:{{account_uuid}}> .
    {
      ?container_uri shst:draft                    ?collection .
    } UNION {
      ?container_uri shst:latest_published_version ?collection .
    }

    ?collection      shst:title                    ?title .
    BIND(STRAFTER(STR(?container_uri), "container:") AS ?container_uuid)
    }
}
{% endblock %}
