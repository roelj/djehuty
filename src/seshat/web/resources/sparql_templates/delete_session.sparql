{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    ?session  ?predicate     ?object .
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?session    rdf:type     shst:Session .
    ?session    shst:token    ?token .
    ?session    ?predicate   ?object .

    FILTER (?token = {{token | safe}})
  }
}
{% endblock %}
