{% extends "prefixes.sparql" %}
{% block query %}
SELECT ?parent_id ?id ?uuid ?title ?source_id ?taxonomy_id
WHERE {
  GRAPH <{{state_graph}}> {
    ?category            rdf:type         shst:Category ;
                         shst:id          ?id ;
                         shst:title       ?title .

    OPTIONAL { ?category shst:parent_id   ?parent_id . }
    OPTIONAL { ?category shst:source_id   ?source_id . }
    OPTIONAL { ?category shst:taxonomy_id ?taxonomy_id . }

    BIND(STRAFTER(STR(?category), "category:") AS ?uuid)
  }
}
{% endblock %}
