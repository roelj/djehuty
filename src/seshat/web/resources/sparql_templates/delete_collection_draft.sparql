{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    ?collection   ?predicate           ?object .
    ?list         shst:index            ?list_index .
    ?list         ?any                 ?list_item .

    ?container    shst:draft           ?collection .
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?container    rdf:type             shst:CollectionContainer ;
                  shst:account          <account:{{account_uuid}}> ;
                  shst:draft            ?collection .

    ?collection   ?predicate           ?object .
    OPTIONAL {
      ?collection ?list_predicate      ?list .
      ?list        rdf:type             rdf:List ;
                   shst:index            ?list_index ;
                   rdf:rest*/rdf:first  ?list_item .
    }
  }

  FILTER (?container = <{{container_uri}}>)
}
{% endblock %}
