{% extends "prefixes.sparql" %}
{% block query %}
SELECT DISTINCT ?subject ?predicate ?object (datatype(?object) AS ?type)
WHERE {
  GRAPH <{{state_graph}}> {
    {%- if full_export: %}
    ?container_uri rdf:type/rdfs:subClassOf shst:Container .
    ?item          shst:container ?container_uri .
    ?item          shst:{{predicate}}/rdf:rest* ?subject .
    {%- else %}
    ?container_uri rdf:type/rdfs:subClassOf shst:Container .
    ?container_uri shst:published_versions/rdf:rest*/rdf:first ?item .
    {
      ?item          shst:{{predicate}}/rdf:rest*/rdf:first ?subject .
    } UNION {
      ?item          shst:{{predicate}}/rdf:rest* ?subject .
    }
    {% endif %}
    ?subject       ?predicate       ?object .
  }
}
{% endblock %}
