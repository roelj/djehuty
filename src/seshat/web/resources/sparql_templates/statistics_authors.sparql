{% extends "prefixes.sparql" %}
{% block query %}
SELECT (COUNT(DISTINCT ?author) AS ?authors)
WHERE {
  GRAPH <{{state_graph}}> {
    ?author         rdf:type            shst:Author .
    ?author         shst:is_public      "true"^^xsd:boolean .
  }
{%- if filters is not none %}{{ filters | safe }}{% endif %}
}
{% endblock %}
