{% extends "prefixes.sparql" %}
{% block query %}
DELETE {
  GRAPH <{{state_graph}}> {
    ?review          shst:assigned_to           ?assigned_to .
    {% if status is not none %}
    ?review          shst:status                ?status .
    {%- endif%}{% if reminder_date is not none %}
    ?review          shst:reminder_date         ?reminder_date .
    {%- endif%}
  }
}
INSERT {
  GRAPH <{{state_graph}}> {
    {%- if assigned_to is not none %}
    ?review          shst:assigned_to          <account:{{assigned_to | safe}}> .
    {%- endif%}{% if status is not none %}
    ?review          shst:status               shst:Review{{status | safe}} .
    {%- endif%}{% if reminder_date is not none %}
    ?review          shst:reminder_date        "{{reminder_date | safe}}"^^xsd:dateTime .
    {%- endif%}
  }
}
WHERE {
  GRAPH <{{state_graph}}> {
    ?review              rdf:type                  shst:Review .
    {%- if dataset_uri is not none %}
    ?review shst:dataset <{{dataset_uri}}>
    {%- endif %}
    OPTIONAL { ?review   shst:assigned_to           ?assigned_to . }
    OPTIONAL { ?review   shst:status                ?status . }
    OPTIONAL { ?review   shst:reminder_date         ?reminder_date . }
  }
  FILTER (?review = <{{review_uri}}>)
}
{% endblock %}
