{% extends "prefixes.sparql" %}
{% block query %}
SELECT ?file_uuid ?dataset_uuid
WHERE {
  GRAPH <{{state_graph}}> {
    ?container        rdf:type        shst:DatasetContainer .
    ?dataset          rdf:type        shst:Dataset .
    ?dataset          shst:container  ?container .
    ?dataset          shst:files/rdf:rest*/rdf:first ?file .
    FILTER NOT EXISTS { ?file shst:computed_md5 ?computer_md5 . }
    BIND (STRAFTER(STR(?file), "file:") AS ?file_uuid)
    BIND (STRAFTER(STR(?dataset), "dataset:") AS ?dataset_uuid)
    FILTER (?container  = <container:{{container_uuid}}>)
  }
}
{% endblock %}
