[Unit]
Description=Seshat data and software repository system.
StartLimitIntervalSec=500
StartLimitBurst=5

[Service]
ExecStart=/usr/bin/seshat web --config-file=/etc/seshat/seshat.xml
Environment=LC_ALL=en_US.utf8
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
