<?xml version="1.0" encoding="utf-8"?>
<seshat>
  <maintenance-mode>0</maintenance-mode>
  <site-name>Seshat example instance</site-name>
  <site-shorttag>example-shorttag</site-shorttag>
  <site-description>Seshat example instance</site-description>
  <support-email-address>support@example.com</support-email-address>
  <!-- <restrict-depositing-to-domain>example.com</restrict-depositing-to-domain> -->
  <colors>
    <primary-color>#7060BB</primary-color>
    <primary-color-hover>#8F80CC</primary-color-hover>
    <primary-color-active>#574899</primary-color-active>
    <privilege-button-color>#BDB5E8</privilege-button-color>
    <footer-background-color>#312B63</footer-background-color>
    <background-color>#F9F8FD</background-color>
  </colors>
  <small-footer>
    <div id="footer-wrapper2">
      <p>This repository is powered by <a href="https://codeberg.org/seshat/seshat">seshat</a>.
      </p>
    </div>
  </small-footer>
  <large-footer>
    <div id="footer-wrapper2">
      <p>This repository is powered by <a href="https://codeberg.org/seshat/seshat">seshat</a>.
      </p>
    </div>
  </large-footer>
  <sandbox-message style="background: #574899; color: #fff;">
    This is an instance launched with the example configuration. Please
    review and modify the configuration file.
  </sandbox-message>
  <notice-message>
    Dear users, if you find a bug, a missing functionality, or if you are having difficulty with the website, please <a href="/feedback">let us know</a>.
  </notice-message>
  <bind-address>127.0.0.1</bind-address>
  <port>8080</port>
  <base-url>http://localhost:8080</base-url>
  <storage-root>./data</storage-root>
  <cache-root clear-on-start="1">./data/cache</cache-root>
  <live-reload>1</live-reload>
  <!-- <log-file>/var/log/seshat.log</log-file> -->
  <debug-mode>1</debug-mode>
  <production>0</production>
  <show-portal-summary>1</show-portal-summary>
  <show-institutions>1</show-institutions>
  <show-science-categories>1</show-science-categories>
  <enable-query-audit-log>1</enable-query-audit-log>
  <show-latest-datasets>1</show-latest-datasets>
  <disable-2fa>1</disable-2fa>
  <use-x-forwarded-for>0</use-x-forwarded-for>
  <!-- <maximum-workers>4</maximum-workers> -->
  <rdf-store>
    <sparql-uri>http://localhost:8890/sparql</sparql-uri>
    <sparql-update-uri>http://localhost:8890/sparql</sparql-update-uri>
    <state-graph>seshat://local</state-graph>
  </rdf-store>
  <datacite>
    <api-url>https://api.datacite.org</api-url>
    <repository-id><!-- Repository ID received from DataCite. --></repository-id>
    <password><!-- Password for this repository ID. --></password>
    <prefix>10.5438</prefix>
  </datacite>
  <handle>
    <url>https://epic-pid.storage.surfsara.nl:800X/api/handles</url>
    <index>XXX</index>
    <certificate><!-- Contents here of the certificate PEM file without newlines/header/footer. --></certificate>
    <private-key><!-- Contents here of the private key PEM file without newlines/header/footer. --></private-key>
    <prefix>XX.XXXXX</prefix>
  </handle>
  <authentication>
    <!--
    <automatic-login-email>you@example.com</automatic-login-email>
    -->
    <orcid>
      <client-id><!-- APP-XXXXXXXXXXXXXXXX --></client-id>
      <client-secret><!-- XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX --></client-secret>
      <endpoint>https://orcid.org/oauth</endpoint>
    </orcid>
  </authentication>
  <email>
    <server><!-- smtp.example.com --></server>
    <port>587</port>
    <starttls>1</starttls>
    <username><!-- Username for the SMTP server. --></username>
    <password><!-- Password for the e-mail account. --></password>
    <from><!-- noreply@example.com --></from>
  </email>
  <privileges>
    <account first_name="Seshat" last_name="" email="seshat@seshat.software" orcid="XXXX-XXXX-XXXX-XXXX">
      <may-administer>1</may-administer>
      <may-run-sparql-queries>1</may-run-sparql-queries>
      <may-impersonate>1</may-impersonate>
      <may-review>1</may-review>
      <may-review-quotas>1</may-review-quotas>
      <may-review-institution>1</may-review-institution>
      <may-review-integrity>1</may-review-integrity>
      <may-process-feedback>0</may-process-feedback>
      <may-recalculate-statistics>1</may-recalculate-statistics>
      <may-receive-email-notifications>1</may-receive-email-notifications>
    </account>
    <account first_name="Seshat" last_name="" email="feedback@seshat.software">
      <may-process-feedback>1</may-process-feedback>
    </account>
  </privileges>
  <groups>
    <group name="House of Life" domain="perankh.seshat.software" id="1" parent_id="0">
      <member is_supervisor="1" email="seshat@seshat.software" first_name="Seshat" />
      <member is_supervisor="1" email="djehuty@seshat.software" first_name="Djehuty" />
    </group>
    <group name="Record-keeping and Archiving" domain="archives.seshat.software" id="100" parent_id="1" is_featured="1">
      <member is_supervisor="1" email="seshat@seshat.software" first_name="Seshat" />
      <member email="imhotep@archives.seshat.software" first_name="Imhotep" />
      <member email="amenhotep@archives.seshat.software" first_name="Amenhotep" last_name="son of Hapu" />
    </group>
    <group name="Writing and Knowledge" domain="knowledge.seshat.software" id="200" parent_id="1" is_featured="1">
      <member is_supervisor="1" email="djehuty@seshat.software" first_name="Djehuty" />
      <member email="horemheb@knowledge.seshat.software" first_name="Horemheb" />
      <member email="kenhirkhopeshef@knowledge.seshat.software" first_name="Kenhirkhopeshef" />
    </group>
    <group name="Measurement and Time" domain="measurement.seshat.software" id="300" parent_id="1" is_featured="1">
      <member is_supervisor="1" email="seshat@seshat.software" first_name="Seshat" />
      <member is_supervisor="1" email="djehuty@seshat.software" first_name="Djehuty" />
