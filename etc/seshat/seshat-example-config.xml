      <member email="harkhuf@measurement.seshat.software" first_name="Harkhuf" />
    </group>
    <group name="Libraries and Collections" domain="collections.seshat.software" id="400" parent_id="1" is_featured="1">
      <member is_supervisor="1" email="seshat@seshat.software" first_name="Seshat" />
      <member email="manetho@collections.seshat.software" first_name="Manetho" />
      <member email="ipuwer@collections.seshat.software" first_name="Ipuwer" />
    </group>
    <group name="Discovery and Exploration" domain="exploration.seshat.software" id="500" parent_id="1" is_featured="1">
      <member is_supervisor="1" email="seshat@seshat.software" first_name="Seshat" />
      <member email="harkhuf@exploration.seshat.software" first_name="Harkhuf" />
      <member email="hatshepsut@exploration.seshat.software" first_name="Hatshepsut" />
    </group>
    <group name="Justice and Order" domain="maat.seshat.software" id="600" parent_id="1" is_featured="1">
      <member is_supervisor="1" email="maat@seshat.software" first_name="Ma'at" />
      <member email="rekhmire@maat.seshat.software" first_name="Rekhmire" />
